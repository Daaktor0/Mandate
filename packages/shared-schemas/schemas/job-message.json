{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mandate.local/job-message.schema.json",
  "title": "JobMessage",
  "description": "Identifier-only queue payload for a paid Mandate Brief generation job.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "jobId",
    "reportRequestId",
    "userId",
    "confirmedEntityId",
    "attempt",
    "traceId",
    "budgetProfile"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "jobId": { "type": "string", "format": "uuid" },
    "reportRequestId": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "confirmedEntityId": { "type": "string", "format": "uuid" },
    "attempt": { "type": "integer", "minimum": 1, "maximum": 100 },
    "traceId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "budgetProfile": { "type": "string", "minLength": 1, "maxLength": 100 }
  }
}
