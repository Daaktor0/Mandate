{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mandate.local/confirm-entity-request.schema.json",
  "x-mandate-versioned": false,
  "type": "object",
  "title": "ConfirmEntityRequest",
  "description": "Strict user decision for mandatory legal-entity confirmation.",
  "additionalProperties": false,
  "properties": {
    "action": {
      "type": "string",
      "enum": ["confirm", "none_of_these", "refine"]
    },
    "candidateId": { "type": "string", "format": "uuid" },
    "relatedEntityIds": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "maxItems": 2,
      "default": []
    },
    "legalName": { "type": "string", "minLength": 1, "maxLength": 300 },
    "cin": {
      "type": "string",
      "pattern": "^[UL][0-9]{5}[A-Z]{2}[0-9]{4}[A-Z]{3}[0-9]{6}$"
    },
    "state": { "type": "string", "minLength": 1, "maxLength": 100 }
  },
  "required": ["action"]
}
