{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.mandate.local/clarification-set.schema.json",
  "title": "ClarificationSet",
  "description": "Bounded, confidentiality-safe questions produced after entity confirmation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportRequestId",
    "entityId",
    "questions",
    "evidenceIds",
    "sparseData",
    "plannerVersion"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "reportRequestId": { "type": "string", "format": "uuid" },
    "entityId": { "type": "string", "format": "uuid" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "questionId",
          "code",
          "prompt",
          "reason",
          "mandatory",
          "answerKind",
          "answerOptions",
          "confidentialitySafe"
        ],
        "properties": {
          "questionId": { "type": "string", "pattern": "^[a-z0-9_:-]{3,100}$" },
          "code": {
            "type": "string",
            "enum": [
              "client_role",
              "transaction_category",
              "cross_border",
              "known_public_issue"
            ]
          },
          "prompt": { "type": "string", "minLength": 1, "maxLength": 600 },
          "reason": { "type": "string", "minLength": 1, "maxLength": 600 },
          "mandatory": { "type": "boolean" },
          "answerKind": {
            "type": "string",
            "enum": ["single_select", "optional_select", "short_text"]
          },
          "answerOptions": {
            "type": "array",
            "maxItems": 6,
            "items": { "type": "string", "minLength": 1, "maxLength": 100 }
          },
          "confidentialitySafe": { "const": true }
        }
      }
    },
    "evidenceIds": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "format": "uuid" }
    },
    "sparseData": { "type": "boolean" },
    "plannerVersion": {
      "type": "string",
      "pattern": "^[A-Za-z0-9.-]{1,64}$"
    }
  }
}
