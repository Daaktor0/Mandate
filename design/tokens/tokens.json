      "insufficientEvidence": {
        "fg": "#5A6270",
        "bg": "#EFEEE9",
        "border": "#D8D5CC",
        "shape": "dashed-dot",
        "label": "Insufficient evidence"
      }
    },
    "claimType": {
      "verifiedFact": {
        "fg": "#1F5B33",
        "bg": "#E7F2EA",
        "border": "#BFDCC8",
