        "label": "Failed — entitlement restored"
      },
      "deleted": {
        "fg": "#6B7280",
        "bg": "#EFEEE9",
        "border": "#D8D5CC",
        "icon": "dash",
        "label": "Deleted"
      }
    },
    "confidence": {
      "strongMatch": {
        "fg": "#1F5B33",
        "bg": "#E7F2EA",
        "border": "#BFDCC8",
