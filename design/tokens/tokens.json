      },
      "inference": {
        "fg": "#7A5410",
        "bg": "#FBF3E0",
        "border": "#E8D5A4",
        "marker": "tilde",
        "label": "Inference"
      },
      "conflict": {
        "fg": "#9B2C1F",
        "bg": "#FAE9E6",
        "border": "#EBC3BB",
        "marker": "bang",
        "label": "Conflict"
      },
      "notPubliclyAvailable": {
        "fg": "#5A6270",
        "bg": "#EFEEE9",
        "border": "#D8D5CC",
        "marker": "dash",
        "label": "Not publicly available"
      }
    },
    "feedback": {
      "successFg": "#1F5B33",
      "successBg": "#E7F2EA",
      "warningFg": "#7A5410",
      "warningBg": "#FBF3E0",
      "dangerFg": "#9B2C1F",
      "dangerBg": "#FAE9E6",
      "infoFg": "#1E4E79",
      "infoBg": "#E9F0F8",
      "unsupportedTextFg": "#7A5410",
      "unsupportedTextBg": "#FFFBEF",
      "unsupportedTextUnderline": "#D9A93F"
    }
  },
  "typography": {
    "ui": {
      "family": "IBM Plex Sans",
      "fallback": "system-ui, sans-serif",
      "license": "SIL OFL 1.1 — self-hosted web + PDF embedding permitted",
      "features": "tnum for tables, clean ₹"
    },
    "document": {
      "family": "Source Serif 4",
      "fallback": "Georgia, serif",
      "license": "SIL OFL 1.1 — self-hosted web + PDF embedding permitted",
      "features": "optical sizes, tnum, ₹ verified"
    },
    "mono": {
      "family": "IBM Plex Mono",
      "fallback": "monospace",
      "use": "CIN, dates in tables, figures",
      "license": "SIL OFL 1.1"
    },
    "scaleUI": {
      "display": {
        "px": 28,
        "weight": 600,
        "lineHeight": "36px",
        "tracking": "-0.01em"
      },
      "h1": {
        "px": 22,
        "weight": 600,
        "lineHeight": "30px",
        "tracking": "-0.01em"
      },
      "h2": {
        "px": 17,
        "weight": 600,
        "lineHeight": "24px"
      },
      "bodyLg": {
        "px": 16,
        "weight": 400,
        "lineHeight": "24px"
      },
      "body": {
        "px": 14.5,
        "weight": 400,
        "lineHeight": "22px"
      },
      "small": {
        "px": 13,
        "weight": 400,
        "lineHeight": "18px"
      },
      "caption": {
        "px": 12,
        "weight": 500,
        "lineHeight": "16px",
        "tracking": "0.02em"
      },
      "overline": {
        "px": 11,
        "weight": 600,
        "lineHeight": "14px",
        "tracking": "0.08em",
        "transform": "uppercase"
      },
      "mono": {
        "px": 13,
        "weight": 400,
        "lineHeight": "18px",
        "features": "tnum"
      }
    },
    "scalePrint": {
      "docTitle": {
        "pt": 16,
        "weight": 600,
        "lineHeight": 1.25
      },
      "metaBlock": {
        "pt": 9,
        "weight": 400,
        "lineHeight": 1.4
      },
      "sectionHead": {
        "pt": 11,
        "weight": 600,
        "lineHeight": 1.3,
        "tracking": "0.01em"
      },
      "subHead": {
        "pt": 10,
        "weight": 600,
        "lineHeight": 1.35
      },
      "body": {
        "pt": 10,
        "weight": 400,
        "lineHeight": 1.45
      },
      "tableBody": {
        "pt": 9.5,
        "weight": 400,
        "lineHeight": 1.4
      },
      "annex": {
        "pt": 9,
        "weight": 400,
        "lineHeight": 1.4
      },
      "disclaimer": {
        "pt": 8.5,
        "weight": 400,
        "lineHeight": 1.4
      }
    }
  },
  "spacing": {
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 24,
    "6": 32,
    "7": 48,
    "8": 64
  },
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 10,
    "xl": 14,
    "pill": 999
  },
  "elevation": {
    "card": "0 1px 2px rgba(26,36,48,.05)",
    "raised": "0 2px 8px rgba(26,36,48,.08)",
    "overlay": "0 8px 28px rgba(26,36,48,.14)",
    "modal": "0 16px 48px rgba(26,36,48,.20)"
  }
}