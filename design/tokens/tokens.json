{
  "meta": {
    "product": "Mandate",
    "theme": "light",
    "version": "1.0",
    "contrast": "WCAG 2.1 AA for all fg/bg pairs; statuses & labels carry icon/shape + text, never colour alone"
  },
  "color": {
    "brand": {
      "primary": "#1E3A5F",
      "primaryHover": "#16304F",
      "primaryActive": "#122840",
      "onPrimary": "#FFFFFF",
      "accentLink": "#1D4E89",
      "accentLinkHover": "#163C6A",
      "accentSeal": "#A63D2F",
      "accentSealNote": "Reserved for the wordmark full point and rare emphasis; never for status meaning"
    },
    "surface": {
      "page": "#FAF9F5",
      "raised": "#FFFFFF",
      "sunken": "#F1EFE9",
      "inverse": "#1E3A5F",
      "document": "#FFFFFF"
    },
    "text": {
      "primary": "#1A2430",
      "secondary": "#4A5568",
      "tertiary": "#6B7280",
      "onInverse": "#FFFFFF",
      "onInverseMuted": "#C9D4E2",
      "disabled": "#9AA1AC"
    },
    "border": {
      "default": "#E3E0D8",
      "strong": "#C9C4B8",
      "divider": "#EDEAE2",
      "focus": "#1D4E89",
      "inputHover": "#A9B2BF"
    },
    "status": {
      "entityConfirmationRequired": {
        "fg": "#7A5410",
        "bg": "#FBF3E0",
        "border": "#E8D5A4",
        "icon": "diamond-outline",
        "label": "Entity confirmation required"
      },
      "clarificationRequired": {
        "fg": "#7A5410",
        "bg": "#FBF3E0",
        "border": "#E8D5A4",
        "icon": "question",
        "label": "Clarification required"
      },
      "queued": {
        "fg": "#4A5568",
        "bg": "#F1EFE9",
        "border": "#D8D5CC",
        "icon": "clock",
        "label": "Queued"
      },
      "researching": {
        "fg": "#1E4E79",
        "bg": "#E9F0F8",
        "border": "#C5D7EA",
        "icon": "progress-1",
        "label": "Researching"
      },
      "verifying": {
        "fg": "#1E4E79",
        "bg": "#E9F0F8",
        "border": "#C5D7EA",
        "icon": "progress-2",
        "label": "Verifying"
      },
      "drafting": {
        "fg": "#1E4E79",
        "bg": "#E9F0F8",
        "border": "#C5D7EA",
        "icon": "progress-3",
        "label": "Drafting"
      },
      "preparingMandateBrief": {
        "fg": "#1E4E79",
        "bg": "#E9F0F8",
        "border": "#C5D7EA",
        "icon": "progress-4",
        "label": "Preparing Mandate Brief"
      },
      "ready": {
        "fg": "#1F5B33",
        "bg": "#E7F2EA",
        "border": "#BFDCC8",
        "icon": "check",
        "label": "Ready"
      },
      "failedEntitlementRestored": {
        "fg": "#7C382A",
        "bg": "#F7EDE9",
        "border": "#E4C6BA",
